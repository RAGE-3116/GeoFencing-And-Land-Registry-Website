# Cloudinary Configuration
# Get your credentials from: https://cloudinary.com/console

# Step 1: Create a free Cloudinary account
# Step 2: Copy these values from your dashboard
# Step 3: Rename this file to .env
# Step 4: Fill in your actual values (replace the placeholders)

CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Example (replace with your actual values):
# CLOUDINARY_CLOUD_NAME=demo-app-12345
# CLOUDINARY_API_KEY=123456789012345
# CLOUDINARY_API_SECRET=abcdefghijklmnopqrstuvwxyz1234

# ⚠️ IMPORTANT:
# - Never commit the actual .env file to Git
# - Make sure .env is in your .gitignore
# - For Render deployment, add these as environment variables in the dashboard
